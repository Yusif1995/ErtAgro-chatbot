# --- Azure AD App Registration ---
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret-VALUE

# --- Power BI Datasets ---
# JSON formatında çoxlu dataset siyahısı.
# Hər birinə bir ad, workspace_id və dataset_id ver.
# Örnək: [{"name":"Sales","workspace_id":"...","dataset_id":"..."}]
DATASETS_JSON=[{"name":"Əsas Dataset","workspace_id":"b55aa2d2-e811-4d59-9a96-58508564d57b","dataset_id":"ad69c614-30e4-4559-9dbf-8052f6febfe1"}]

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21
